# Optional LLM settings. Keep real API keys in .env only; never commit .env.
# OPENAI_API_KEY=
# HR_LLM_ENABLED=false
# HR_LLM_API_KEY=
# HR_LLM_MODEL=
# HR_LLM_BASE_URL=https://api.openai.com/v1/chat/completions
# HR_LLM_TIMEOUT_SECONDS=30
# HR_LLM_IGNORE_PROXY=true
# HR_LLM_PDF_MAX_PAGES=3

# OCR fallback settings.
# HR_IMAGE_PDF_PARSE_STRATEGY=vision_first
# HR_ENABLE_LOCAL_OCR=false
# HR_OCR_TIMEOUT_SECONDS=12

# Optional SMTP settings for sending batch reports from the control cabin.
# HR_SMTP_HOST=smtp.example.com
# HR_SMTP_PORT=465
# HR_SMTP_USERNAME=your-email@example.com
# HR_SMTP_PASSWORD=your-smtp-app-password
# HR_SMTP_FROM=your-email@example.com
# HR_SMTP_USE_SSL=true
