# Optional LLM settings. Keep real API keys in .env only; never commit .env.
# Database settings. Leave HR_DATABASE_URL empty to use local SQLite.
# HR_SQLITE_PATH=data/hr_runs.sqlite3
# HR_DATABASE_URL=
# Example PostgreSQL URL:
# HR_DATABASE_URL=postgresql+psycopg://agentic_hr:agentic_hr_password@localhost:5432/agentic_hr

# OPENAI_API_KEY=
# HR_LLM_ENABLED=false
# HR_LLM_PROVIDER=openai_compatible
# HR_LLM_API_KEY=
# HR_LLM_MODEL=
# HR_LLM_BASE_URL=https://api.openai.com/v1/chat/completions
# HR_LLM_TIMEOUT_SECONDS=30
# HR_LLM_IGNORE_PROXY=true
# HR_LLM_PDF_MAX_PAGES=3
# HR_LLM_STRUCTURED_EXTRACTION_ENABLED=false
# HR_AGENT_LLM_ENABLED=false

# Local Ollama example for lower-spec laptops:
# HR_LLM_ENABLED=true
# HR_LLM_PROVIDER=ollama
# HR_LLM_API_KEY=local
# HR_LLM_MODEL=qwen3:1.7b
# HR_LLM_BASE_URL=http://localhost:11434/v1
# HR_LLM_TIMEOUT_SECONDS=120
# HR_LLM_STRUCTURED_EXTRACTION_ENABLED=false
# HR_AGENT_LLM_ENABLED=true

# OCR fallback settings.
# HR_IMAGE_PDF_PARSE_STRATEGY=ocr_first
# HR_ENABLE_LOCAL_OCR=true
# HR_OCR_TIMEOUT_SECONDS=12

# Optional Redis runtime status / future queue backend.
# Keep unset for local single-process development.
# HR_REDIS_URL=redis://localhost:6379/0

# Optional SMTP settings for sending batch reports from the control cabin.
# HR_SMTP_HOST=smtp.example.com
# HR_SMTP_PORT=465
# HR_SMTP_USERNAME=your-email@example.com
# HR_SMTP_PASSWORD=your-smtp-app-password
# HR_SMTP_FROM=your-email@example.com
# HR_SMTP_USE_SSL=true
